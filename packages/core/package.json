{
  "name": "config-driven-testimonials",
  "version": "1.2.0",
  "description": "Config-driven React testimonials widget — drop in your config, get a polished UI",
  "keywords": [
    "testimonials",
    "react",
    "widget",
    "config-driven",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KKeylin/config-driven-recommendations"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tailwindcss -i src/styles.css -o dist/styles.css --minify && node scripts/css-to-ts.mjs && tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@config-driven-testimonials/config-schema": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "tailwindcss": "^4",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}